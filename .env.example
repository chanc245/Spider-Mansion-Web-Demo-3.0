# Copy this file to ".env" and fill in your keys.
# The .env file is git-ignored.

# OpenAI — powers the AI quiz conversation (server /submit endpoint).
# Required unless you use a local Ollama model (AI_PROVIDER=local below).
OPENAI_API_KEY=

# Optional — chat model used for the quiz AI (defaults to "gpt-4.1").
OPENAI_MODEL=

# Optional — which AI runs the quiz: "openai" (ChatGPT, default) or "local"
# (free local model via Ollama — see README "Running the quiz AI locally").
# Can also be switched live from the ?debug panel or the in-game AI gate.
AI_PROVIDER=

# Optional — Ollama model when AI_PROVIDER=local (defaults to "qwen3:8b";
# use "llama3.2" on low-spec machines) and the Ollama server address
# (defaults to "http://localhost:11434/v1").
OLLAMA_MODEL=
OLLAMA_BASE_URL=

# Optional — Hugging Face provider (AI_PROVIDER=hf): model on the HF Inference
# router (defaults to "Qwen/Qwen3-8B") and an optional built-in token
# (players can bring their own free token via the AI gate instead).
HF_MODEL=
HF_API_KEY=

# ElevenLabs — powers Eva's spoken voice / TTS (server /tts endpoint).
# Optional: without it the game still runs, just with no voice.
ELEVEN_LABS_API_KEY=

# Password for the ?debug panel and the server-wide AI-provider switch.
# No default — leave unset to disable the debug features entirely.
DEBUG_PASSWORD=

# Optional — port the server listens on (defaults to 3001).
PORT=
