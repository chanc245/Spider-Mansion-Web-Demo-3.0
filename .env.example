# Copy this file to ".env" and fill in your keys.
# The .env file is git-ignored.

# OpenAI — powers the AI quiz conversation (server /submit endpoint). Required.
OPENAI_API_KEY=

# Optional — chat model used for the quiz AI (defaults to "gpt-4.1").
OPENAI_MODEL=

# ElevenLabs — powers Eva's spoken voice / TTS (server /tts endpoint).
# Optional: without it the game still runs, just with no voice.
ELEVEN_LABS_API_KEY=

# Optional — port the server listens on (defaults to 3001).
PORT=
